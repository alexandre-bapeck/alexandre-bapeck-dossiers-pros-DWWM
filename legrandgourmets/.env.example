# =====================================================================
#  Configuration SMTP — Mission 3 (envoi d'e-mails via PHPMailer)
# =====================================================================
#  Copier ce fichier en ".env" puis remplir avec TES identifiants.
#  Le .env n'est JAMAIS versionné (voir .gitignore) : il contient des secrets.
#
#  Pour obtenir ces valeurs : https://mailtrap.io
#    Email Testing > Inboxes > My Inbox > Integrations > PHP > PHPMailer
# =====================================================================

MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=ton_identifiant_mailtrap
MAIL_PASSWORD=ton_mot_de_passe_mailtrap
MAIL_ENCRYPTION=tls

# Expéditeur affiché dans l'e-mail
MAIL_FROM_ADDRESS=noreply@legrandgourmet.fr
MAIL_FROM_NAME="LE GRAND GOURMET"
